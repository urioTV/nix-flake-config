// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // --- UI & THEME ---
  "agent_servers": {
    "pi-acp": {
      "type": "registry",
    },
  },
  "cli_default_open_behavior": "existing_window",
  "collaboration_panel": {
    "dock": "left",
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "eager",
    "disabled_globs": ["**/.env*", "**/*.pem", "**/*.key"],
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "VSCode",
  "buffer_font_fallbacks": ["JetBrainsMono Nerd Font Mono"],
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme",
  },
  "ui_font_family": "Inter Nerd Font",
  "ui_font_size": 12,
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "buffer_font_size": 12,

  "agent": {
    "dock": "right",
    "default_width": 280,
    "default_profile": "write",
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
    },
    "inline_assistant_model": {
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
    },
    "commit_message_model": {
      "provider": "openai-subscribed",
      "model": "gpt-5.4",
    },
    "play_sound_when_agent_done": "when_hidden",
    "tool_permissions": {
      "default": "allow",
    },
  },
  "context_servers": {
    "context7": {
      "url": "https://mcp.context7.com/mcp",
    },
    "nixos": {
      "command": "uvx",
      "args": ["mcp-nixos"],
    },
    "github": {
      "command": "github-mcp-server",
      "args": ["stdio"],
    },
    "websearch": {
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa",
    },
    "grep_app": {
      "url": "https://mcp.grep.app",
    },
  },

  // --- LANGUAGE & LSP ---
  "languages": {
    "Nix": {
      "language_servers": ["nixd", "!nil"],
    },
  },
  "lsp": {
    "nixd": {
      "settings": {
        "nixpkgs": {
          "expr": "(builtins.getFlake \"github:urioTV/nix-flake-config\").nixosConfigurations.konrad-m18.pkgs",
        },
        "formatting": {
          "command": ["nixfmt"],
        },
        "options": {
          "nixos": {
            "expr": "(builtins.getFlake \"github:urioTV/nix-flake-config\").nixosConfigurations.konrad-m18.options",
          },
          "home_manager": {
            "expr": "(builtins.getFlake \"github:urioTV/nix-flake-config\").nixosConfigurations.konrad-m18.config.home-manager.users.urio",
          },
        },
      },
    },
  },

  // --- TERMINAL ---
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font Mono",
    "detect_venv": {
      "on": {
        "directories": [".venv", "venv"],
        "activate_script": "default",
      },
    },
  },

  // --- EDITOR BEHAVIOR (VS Code-like) ---
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "soft_wrap": "bounded",
  "preferred_line_length": 120,
  "tab_size": 2,
  "cursor_shape": "bar",
  "cursor_blink": true,
  "current_line_highlight": "all",
  "selection_highlight": true,
  "inlay_hints": {
    "enabled": true,
  },

  // --- UI ELEMENTS (VS Code-like) ---
  "minimap": {
    "show": "always",
    "thumb": "always",
    "current_line_highlight": "line",
  },
  "scrollbar": {
    "axes": {
      "horizontal": true,
      "vertical": true,
    },
    "cursors": true,
    "git_diff": true,
    "search_results": true,
    "selected_symbol": true,
  },
  "tab_bar": {
    "show": true,
  },
  "tabs": {
    "show_diagnostics": "errors",
    "file_icons": true,
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "colorize_brackets": true,
  "sticky_scroll": {
    "enabled": true,
  },
  "gutter": {
    "line_numbers": true,
    "folds": true,
  },
  "outline_panel": {
    "dock": "right",
  },
  "file_finder": {
    "modal_max_width": "xlarge",
  },

  // --- PANELS ---
  "project_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
}
